# Copy to .env.local and fill in your values.
# .env.local is ignored and must not be committed.

VITE_ANALYZE_IMAGE_URL=/api/analyze-image
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
VITE_SCREENSHOT_TO_CODE_WS_URL=

# Google OAuth (optional) — get Client ID from Google Cloud Console → APIs & Services → Credentials
# Leave empty to hide the "Continue with Google" button
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Server-side only. Set this in .env.local for Vercel dev or in the Vercel dashboard for production.
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GROQ_API_KEY=your-groq-api-key-here

# ───────────────────────────────────────────────────────────────────
# Desygn A11y (Move 1) — server-side. All optional locally: the API
# degrades gracefully (auth/quota allow-through) when these are unset.
# See docs/architecture-v6/WEEK1_SETUP.md for how to obtain each value.
# ───────────────────────────────────────────────────────────────────

# Supabase (DEDICATED desygn-a11y project — NOT the Design-md-ai project)
SUPABASE_URL=https://your-a11y-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server only — bypasses RLS, never expose

# Upstash Redis (rate limiting + hourly API quota)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Report signing (PDF/markdown HMAC). Generate: openssl rand -base64 32
REPORT_SIGNING_SECRET=your-32-byte-base64-secret
A11Y_VERIFICATION_URL=https://a11y.desygn.ai/verify

# --- Wired in later weeks (leave blank until then) ---
# Week 5 — Inngest (audit job queue)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Week 7 — Stripe (billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Week 7 — Resend (email)
RESEND_API_KEY=
# Week 11/12 — observability
SENTRY_DSN=
POSTHOG_KEY=
